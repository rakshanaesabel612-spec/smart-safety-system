# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Optional: EmailJS settings for SOS email alerts.
# Create a service and template in EmailJS, then provide these values.
EMAILJS_SERVICE_ID="YOUR_EMAILJS_SERVICE_ID"
EMAILJS_TEMPLATE_ID="YOUR_EMAILJS_TEMPLATE_ID"
EMAILJS_PUBLIC_KEY="YOUR_EMAILJS_PUBLIC_KEY"
# Optional private key for server-side EmailJS requests.
EMAILJS_PRIVATE_KEY="YOUR_EMAILJS_PRIVATE_KEY"
# Optional display name in template params.
EMAILJS_FROM_NAME="GuardianAI Alerts"

# WhatsApp via smsalert.co API
SMSALERT_WHATSAPP_API_KEY="YOUR_SMSALERT_WHATSAPP_API_KEY"
SMSALERT_WHATSAPP_SENDER_ID="SENDER"
SMSALERT_WHATSAPP_ROUTE="whatsapp"
SMSALERT_WHATSAPP_URL="https://www.smsalert.co.in/api/mwhatsapp.php"
SMSALERT_WHATSAPP_DEFAULT_COUNTRY_CODE="91"
SMSALERT_WHATSAPP_TEXT_PARAM="text"
SMSALERT_WHATSAPP_APIKEY_PARAM="apikey"
SMSALERT_WHATSAPP_MOBILE_PARAM="mobileno"
SMSALERT_WHATSAPP_SENDER_PARAM="sender"
SMSALERT_WHATSAPP_ROUTE_PARAM="route"

# If smsalert.co WhatsApp or EmailJS email settings are not configured, SOS alerts run in simulated mode.
